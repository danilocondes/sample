@page "/"
@inject IJSRuntime JS

<PageTitle>Counter Web App</PageTitle>

<section class="counter-card">
    <p class="eyebrow">Simple .NET C# web application</p>
    <h1>Counter</h1>
    <p class="description">
        Click either button below to change the counter. Each click is monitored with PostHog.
    </p>

    <div class="counter-display" aria-live="polite">
        <span class="counter-label">Current count</span>
        <strong>@currentCount</strong>
    </div>

    <div class="counter-actions" aria-label="Counter actions">
        <button class="counter-button counter-button-secondary" @onclick="DecrementCount">Subtract 1</button>
        <button class="counter-button" @onclick="IncrementCount">Add 1</button>
    </div>
</section>

@code {
    private int currentCount;

    private Task IncrementCount()
    {
        return UpdateCount("increment", 1);
    }

    private Task DecrementCount()
    {
        return UpdateCount("decrement", -1);
    }

    private async Task UpdateCount(string action, int delta)
    {
        currentCount += delta;

        await JS.InvokeVoidAsync("counterAnalytics.captureCounterClick", action, currentCount, delta);
    }
}
